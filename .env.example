PORT=8098
HOST=127.0.0.1
APP_VERSION=local-dev
NODE_ENV=local

# Render normally supplies PORT. Leave HOST blank on Render so the app binds to 0.0.0.0 automatically.
# Use PUBLIC_BASE_URL only when generated links must always use a specific public domain.
PUBLIC_BASE_URL=
COOKIE_SECURE=false

# Principal/admin sign-in accepts any one of these names. ADMIN_PASSWORD is kept because it is the
# easiest Render variable name to remember.
ADMIN_PASSWORD=AxiomAdmin2026!
ADMIN_ACCESS_KEY=AxiomAdmin2026!
PRINCIPAL_ACCESS_KEY=AxiomAdmin2026!
OFFICE_ADMIN_ACCESS_KEY=AxiomOffice2026!
AGENT_ACCESS_KEY=AxiomAgent2026!
BUYER_ACCESS_KEY=AxiomBuyer2026!
SELLER_ACCESS_KEY=AxiomSeller2026!
ATTORNEY_ACCESS_KEY=AxiomAttorney2026!
BOND_ORIGINATOR_ACCESS_KEY=AxiomBond2026!
PRINCIPAL_SIGNIN_CONTACT=principal@axiom.local
OFFICE_ADMIN_SIGNIN_CONTACT=office@axiom.local
AGENT_SIGNIN_CONTACT=agent@axiom.local
BUYER_SIGNIN_CONTACT=buyer@axiom.local
SELLER_SIGNIN_CONTACT=seller@axiom.local
ATTORNEY_SIGNIN_CONTACT=attorney@axiom.local
BOND_ORIGINATOR_SIGNIN_CONTACT=bond@axiom.local
MISSION_CONTROL_SESSION_HOURS=8
MISSION_CONTROL_OTP_MINUTES=10
MISSION_CONTROL_OTP_PREVIEW=true

# WhatsApp delivery. Keep managed-simulation for local/manual testing.
# For real delivery later: WHATSAPP_PROVIDER=meta-cloud plus the Meta values below.
WHATSAPP_MODE=managed-simulation
WHATSAPP_PROVIDER=managed-simulation
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_API_BASE_URL=https://graph.facebook.com
WHATSAPP_API_VERSION=v20.0
WHATSAPP_FROM_NUMBER=

# OTP and email are deliberately explicit so the status endpoint can say what is real.
OTP_PROVIDER=preview
EMAIL_PROVIDER=none
EMAIL_FROM=

# Live AI provider. Keep keys in Render/local environment variables, never in GitHub.
LLM_PROVIDER=nvidia
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=z-ai/glm-5.2
NVIDIA_FALLBACK_MODEL=nvidia/nemotron-3-ultra-550b-a55b

# Optional OpenAI fallback/provider support.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Database foundation. The current app still runs on JSON files,
# but these values are ready for the database migration step.
DATABASE_URL=
STORAGE_MODE=auto
STORAGE_TABLE_NAME=axiom_state_blobs
DB_HOST=postgres
DB_PORT=5432
DB_NAME=axiom
DB_USER=axiom
DB_PASSWORD=axiom
﻿PORT=8080
PUBLIC_BASE_URL=http://localhost:8080
ALLOWED_ORIGIN=http://localhost:8080
ADMIN_PASSWORD=change-this-before-launch
ENFORCE_PRODUCTION_ENV=false

# Local LM Studio helper for the AI concierge. Local defaults are safe:
# Render keeps this off unless LM_STUDIO_ENABLED=true is set there.
LM_STUDIO_ENABLED=true
LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
LM_STUDIO_MODEL=
LM_STUDIO_API_KEY=lm-studio
LM_STUDIO_TIMEOUT_MS=1800

# WhatsApp Cloud API (optional for Phase 1)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TO_NUMBER=27XXXXXXXXX
WHATSAPP_AUTO_SEND=false

# Optional speech-to-text endpoint for incoming WhatsApp voice notes.
# Point this at an HTTPS endpoint that accepts multipart form-data: file + model.
WHATSAPP_VOICE_TRANSCRIBE_URL=
WHATSAPP_VOICE_TRANSCRIBE_API_KEY=
WHATSAPP_VOICE_TRANSCRIBE_MODEL=whisper-1
WHATSAPP_VOICE_TRANSCRIBE_TIMEOUT_MS=30000
WHATSAPP_VOICE_TRANSCRIBE_REQUIRED=false
WHATSAPP_VOICE_TRANSCRIBE_MAX_BYTES=16777216

# Customer portal access via WhatsApp OTP.
CLIENT_PORTAL_SESSION_HOURS=8
CLIENT_WHATSAPP_OTP_MINUTES=10
CLIENT_WHATSAPP_OTP_MAX_ATTEMPTS=5

# WhatsApp Web bridge for pre-launch testing only. Do not use as production infrastructure.
WHATSAPP_WEB_TEST_MODE=false
CHROME_EXECUTABLE_PATH=

# Optional operations notification webhook. When configured, the OS posts queued messages here.
OPERATIONS_NOTIFICATION_WEBHOOK_URL=
OPERATIONS_EMAIL_WEBHOOK_URL=
OPERATIONS_WEBHOOK_SECRET=
CONCIERGE_EMAIL=
OPERATIONS_SWEEP_INTERVAL_MS=300000
OPERATIONS_DELIVERY_INTERVAL_MS=60000
SLA_MINUTES=10
LEAD_ACK_ESCALATION_MINUTES=10
LEAD_REFERRED_CONTACT_ESCALATION_HOURS=24
LEAD_COMMISSION_RISK_ESCALATION_HOURS=48
LEAD_DEDUPE_WINDOW_DAYS=45
STAKEHOLDER_LINK_TTL_DAYS=30
AUTO_LEAD_AUTOMATION_ENABLED=true
LEAD_AUTOMATION_INTERVAL_MS=60000
LEAD_PROACTIVE_ACK_DAYS=0
LEAD_PROACTIVE_MISSING_DOCS_DAYS=1
LEAD_PROACTIVE_STATUS_CHECK_DAYS=3
LEAD_PROACTIVE_REACTIVATION_DAYS=7
LEAD_PROACTIVE_COOLDOWN_HOURS=6
LEAD_PROACTIVE_QUIET_START_HOUR=8
LEAD_PROACTIVE_QUIET_END_HOUR=19
AUTO_CONCIERGE_DIGEST_ENABLED=true
AUTO_CONCIERGE_DIGEST_HOUR=8
AUTO_CONCIERGE_DIGEST_MINUTE=0

# Local OS demo login only. Disable this before production launch.
OPERATIONS_DEMO_MODE=true
OPERATIONS_DEMO_CELLPHONE=+27832803176
OPERATIONS_DEMO_PIN=1234

# Optional Render deploy hook for instant publish after push.
# Example:
# https://api.render.com/deploy/srv-XXXXXXXXXXX?key=...
RENDER_DEPLOY_HOOK_URL=
