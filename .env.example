PORT=8080
PUBLIC_BASE_URL=http://localhost:8080
ALLOWED_ORIGIN=http://localhost:8080
ADMIN_PASSWORD=change-this-before-launch

# WhatsApp Cloud API (optional for Phase 1)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TO_NUMBER=27XXXXXXXXX
WHATSAPP_AUTO_SEND=false

# WhatsApp Web bridge for pre-launch testing only. Do not use as production infrastructure.
WHATSAPP_WEB_TEST_MODE=false
CHROME_EXECUTABLE_PATH=

# Optional operations notification webhook. When configured, the OS posts queued messages here.
OPERATIONS_NOTIFICATION_WEBHOOK_URL=
OPERATIONS_EMAIL_WEBHOOK_URL=
OPERATIONS_WEBHOOK_SECRET=
CONCIERGE_EMAIL=
OPERATIONS_SWEEP_INTERVAL_MS=300000
OPERATIONS_DELIVERY_INTERVAL_MS=60000
SLA_MINUTES=10
LEAD_ACK_ESCALATION_MINUTES=10
LEAD_REFERRED_CONTACT_ESCALATION_HOURS=24
LEAD_COMMISSION_RISK_ESCALATION_HOURS=48
LEAD_DEDUPE_WINDOW_DAYS=45
STAKEHOLDER_LINK_TTL_DAYS=30
AUTO_LEAD_AUTOMATION_ENABLED=true
LEAD_AUTOMATION_INTERVAL_MS=60000
AUTO_CONCIERGE_DIGEST_ENABLED=true
AUTO_CONCIERGE_DIGEST_HOUR=8
AUTO_CONCIERGE_DIGEST_MINUTE=0

# Local OS demo login only. Disable this before production launch.
OPERATIONS_DEMO_MODE=true
OPERATIONS_DEMO_CELLPHONE=+27832803176
OPERATIONS_DEMO_PIN=1234
